<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_in_edi_document_list" model="ir.ui.view">
        <field name="name">in_edi.document.list</field>
        <field name="model">in_edi.document</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'authorized'"
                  decoration-danger="state in ('returned','rejected')"
                  decoration-info="state in ('signed','sent')">
                <field name="create_date"/>
                <field name="move_id"/>
                <field name="access_key"/>
                <field name="environment"/>
                <field name="state"/>
                <field name="authorization_date"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_in_edi_document_form" model="ir.ui.view">
        <field name="name">in_edi.document.form</field>
        <field name="model">in_edi.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_send_to_sri" type="object"
                            string="Send to SRI" class="oe_highlight"
                            invisible="state == 'authorized' or not xml_signed_file"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="move_id"/>
                            <field name="access_key"/>
                            <field name="environment"/>
                        </group>
                        <group>
                            <field name="authorization_number"/>
                            <field name="authorization_date"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Files">
                        <field name="xml_file" filename="xml_filename"/>
                        <field name="xml_filename" invisible="1"/>
                        <field name="xml_signed_file" filename="xml_signed_filename"/>
                        <field name="xml_signed_filename" invisible="1"/>
                    </group>
                    <group string="SRI Messages">
                        <field name="sri_messages" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_in_edi_document" model="ir.actions.act_window">
        <field name="name">SRI Documents</field>
        <field name="res_model">in_edi.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_in_edi_document"
              name="SRI Documents"
              parent="account.menu_finance_entries"
              action="action_in_edi_document"
              sequence="50"/>

</odoo>
