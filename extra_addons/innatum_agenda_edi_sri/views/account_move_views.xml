<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_move_form_in_edi" model="ir.ui.view">
        <field name="name">account.move.form.in_edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//button[@name='action_post']" position="before">
                <button name="action_in_edi_send" type="object"
                        string="Send to SRI" class="oe_highlight"
                        invisible="state != 'posted'
                                   or move_type not in ('out_invoice','out_refund')
                                   or in_edi_state == 'authorized'
                                   or not journal_id"
                        groups="account.group_account_invoice"/>
            </xpath>

            <xpath expr="//sheet/*[1]" position="before">
                <widget name="web_ribbon" title="Autorizada SRI"
                        bg_color="text-bg-success"
                        invisible="in_edi_state != 'authorized'"/>
                <widget name="web_ribbon" title="Enviada al SRI"
                        bg_color="text-bg-info"
                        invisible="in_edi_state not in ('signed','sent')"/>
                <widget name="web_ribbon" title="Devuelta por el SRI"
                        bg_color="text-bg-danger"
                        invisible="in_edi_state not in ('returned','rejected')"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="in_edi_sri" string="SRI"
                      invisible="move_type not in ('out_invoice','out_refund')">
                    <group>
                        <field name="in_edi_access_key"/>
                        <field name="in_edi_state"/>
                    </group>
                    <field name="in_edi_document_ids" readonly="1">
                        <list decoration-success="state == 'authorized'"
                              decoration-info="state == 'sent'"
                              decoration-danger="state in ('returned','rejected')">
                            <field name="access_key"/>
                            <field name="environment"/>
                            <field name="state"
                                   widget="badge"
                                   decoration-success="state == 'authorized'"
                                   decoration-info="state == 'sent'"
                                   decoration-danger="state in ('returned','rejected')"/>
                            <field name="authorization_number"/>
                            <field name="authorization_date"/>
                            <field name="sri_messages"/>
                        </list>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
