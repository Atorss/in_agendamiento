<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_in_edi_certificate_list" model="ir.ui.view">
        <field name="name">in_edi.certificate.list</field>
        <field name="model">in_edi.certificate</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'active'"
                  decoration-muted="state in ('expired','revoked')">
                <field name="name"/>
                <field name="subject_cn"/>
                <field name="issuer"/>
                <field name="date_end"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_in_edi_certificate_form" model="ir.ui.view">
        <field name="name">in_edi.certificate.form</field>
        <field name="model">in_edi.certificate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open_validate_wizard" type="object"
                            string="Validate" class="oe_highlight"
                            invisible="not p12_file"/>
                    <button name="action_set_active" type="object"
                            string="Activate" invisible="state == 'active' or not date_end"/>
                    <button name="action_set_revoked" type="object"
                            string="Revoke" invisible="state in ('revoked','draft')"/>
                    <button name="action_set_draft" type="object"
                            string="Reset to Draft" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Certificate 2026"/></h1>
                    </div>
                    <group>
                        <group string="Certificate File">
                            <field name="p12_file" filename="p12_filename"/>
                            <field name="p12_filename" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Details (read-only)">
                            <field name="subject_cn"/>
                            <field name="issuer"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="is_expired"/>
                        </group>
                    </group>
                    <group string="Usage">
                        <field name="last_use"/>
                        <field name="use_count"/>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_in_edi_certificate_validate_wizard" model="ir.ui.view">
        <field name="name">in_edi.certificate.validate.wizard.form</field>
        <field name="model">in_edi.certificate.validate.wizard</field>
        <field name="arch" type="xml">
            <form string="Validate Certificate">
                <field name="certificate_id" invisible="1"/>
                <group>
                    <field name="password" password="True"/>
                </group>
                <footer>
                    <button name="action_validate" type="object"
                            string="Validate" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_in_edi_certificate" model="ir.actions.act_window">
        <field name="name">SRI Certificates</field>
        <field name="res_model">in_edi.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_in_edi_certificate"
              name="SRI Certificates"
              parent="account.menu_finance_configuration"
              action="action_in_edi_certificate"
              sequence="90"/>

</odoo>
