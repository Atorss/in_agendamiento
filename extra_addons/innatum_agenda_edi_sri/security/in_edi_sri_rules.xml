<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Multi-company isolation for SRI electronic invoicing.
         Each tenant (company) must only ever see/use its own signing
         certificate (private key) and its own emitted documents.
         Global rules: applied in AND to every group, present and future.
         ============================================================ -->

    <record id="rule_in_edi_certificate_company" model="ir.rule">
        <field name="name">SRI certificate: own company only</field>
        <field name="model_id" ref="model_in_edi_certificate"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

    <record id="rule_in_edi_document_company" model="ir.rule">
        <field name="name">SRI document: own company only</field>
        <field name="model_id" ref="model_in_edi_document"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

</odoo>
