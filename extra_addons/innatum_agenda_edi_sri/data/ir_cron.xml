<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cron_in_edi_check_certificate_expiration" model="ir.cron">
        <field name="name">SRI: Mark expired certificates</field>
        <field name="model_id" ref="model_in_edi_certificate"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_expiration()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_in_edi_query_pending_authorizations" model="ir.cron">
        <field name="name">SRI: Poll pending authorizations</field>
        <field name="model_id" ref="model_in_edi_document"/>
        <field name="state">code</field>
        <field name="code">model._cron_query_pending_authorizations()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
