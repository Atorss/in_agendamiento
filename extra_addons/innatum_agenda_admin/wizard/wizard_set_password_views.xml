<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_set_password_form" model="ir.ui.view">
        <field name="name">innatum.agenda.admin.wizard.set_password.form</field>
        <field name="model">innatum.agenda.admin.wizard.set_password</field>
        <field name="arch" type="xml">
            <form string="Establecer Contraseña">
                <group>
                    <field name="employee_id" invisible="1"/>
                    <field name="user_login"/>
                    <field name="password" password="True"/>
                    <field name="password_confirm" password="True"/>
                </group>
                <footer>
                    <button name="action_set_password" type="object"
                            string="Guardar Contraseña" class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_set_password" model="ir.actions.act_window">
        <field name="name">Establecer Contraseña</field>
        <field name="res_model">innatum.agenda.admin.wizard.set_password</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
