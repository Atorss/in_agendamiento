<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Inserta los menús raíz "Mi Negocio" y "Agendamiento" en el grupo
             "Administración" de la sidebar MUK. (4, id) suma sin pisar otros
             menús que otros módulos puedan agregar al mismo grupo. -->
        <record id="muk_web_appsbar.menu_group_medic_administracion" model="ir.ui.menu.group">
            <field name="menu_ids" eval="[
                (4, ref('innatum_agenda_admin.innatum_agenda_admin_menu_root')),
                (4, ref('innatum_agenda_core.innatum_agenda_menu_root')),
                (4, ref('hr.menu_hr_root')),
                (4, ref('contacts.menu_contacts')),
            ]"/>
        </record>

        <!-- Restringir "Aplicaciones" (Apps) solo a administradores del sistema.
             Por defecto Odoo 18 lo deja público para que cualquier usuario
             interno pueda "Solicitar acceso", pero en este SaaS no aplica. -->
        <record id="base.menu_management" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

        <!-- Restringir "Tableros" (spreadsheet dashboards) a administradores
             del sistema. -->
        <record id="spreadsheet_dashboard.spreadsheet_dashboard_menu_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
        </record>

    </data>
</odoo>
