<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Horarios de trabajo (resource.calendar) — vista simplificada para
         el admin del tenant en modo de agenda 'directa'.

         Reutiliza el modelo nativo resource.calendar (que el motor de
         disponibilidad ya lee), pero con un form limpio: nombre + líneas
         de horario (día, franja, hora desde/hasta). El aislamiento por
         empresa lo garantizan las record rules de resource_calendar_rules.xml.
         ================================================================ -->

    <record id="innatum_resource_calendar_view_list" model="ir.ui.view">
        <field name="name">innatum.resource.calendar.list</field>
        <field name="model">resource.calendar</field>
        <field name="arch" type="xml">
            <list string="Horarios de trabajo">
                <field name="name"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="innatum_resource_calendar_view_form" model="ir.ui.view">
        <field name="name">innatum.resource.calendar.form</field>
        <field name="model">resource.calendar</field>
        <field name="arch" type="xml">
            <form string="Horario de trabajo">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Ej: Dr. Pérez (Lun/Mié/Vie tarde)"/>
                        </h1>
                    </div>
                    <group>
                        <field name="company_id" readonly="1"
                               groups="base.group_multi_company"/>
                        <field name="tz" string="Zona horaria"/>
                    </group>
                    <group string="Franjas de atención semanal">
                        <field name="attendance_ids" nolabel="1">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="dayofweek"/>
                                <field name="hour_from" widget="float_time"/>
                                <field name="hour_to" widget="float_time"/>
                                <field name="day_period"/>
                            </list>
                        </field>
                    </group>
                    <div class="alert alert-info" role="status">
                        <i class="fa fa-info-circle"/>
                        Cada línea es una franja de atención (ej: Lunes 08:00–12:00).
                        Para partir el día en mañana/tarde, agregá dos líneas del
                        mismo día. Este horario define la disponibilidad del/los
                        colaborador(es) que lo tengan asignado (modo directa).
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="innatum_resource_calendar_action" model="ir.actions.act_window">
        <field name="name">Horarios de trabajo</field>
        <field name="res_model">resource.calendar</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('innatum_resource_calendar_view_list')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('innatum_resource_calendar_view_form')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Creá un horario de trabajo
            </p>
            <p>
                Definí las franjas de atención semanal de tus colaboradores.
                Podés crear un horario por profesional o uno reutilizable para
                un grupo, y asignarlo en la ficha de cada colaborador.
            </p>
        </field>
    </record>

    <!-- Menú dentro de "Configuración" (junto a Servicios). Solo visible en
         modo 'directa' (grupo técnico) + Innatum staff. -->
    <menuitem id="innatum_agenda_menu_horarios_trabajo"
              name="Horarios de trabajo"
              parent="innatum_agenda_core.innatum_agenda_menu_config"
              action="innatum_resource_calendar_action"
              sequence="20"
              groups="innatum_agenda_core.innatum_agenda_group_modo_directa,base.group_system"/>

</odoo>
