<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vertical_template_list" model="ir.ui.view">
        <field name="name">innatum.vertical.template.list</field>
        <field name="model">innatum.vertical.template</field>
        <field name="arch" type="xml">
            <list string="Plantillas de Vertical">
                <field name="code"/>
                <field name="name"/>
                <field name="family"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_vertical_template_form" model="ir.ui.view">
        <field name="name">innatum.vertical.template.form</field>
        <field name="model">innatum.vertical.template</field>
        <field name="arch" type="xml">
            <form string="Plantilla de Vertical">
                <sheet>
                    <widget name="web_ribbon" title="Archivada" bg_color="bg-danger"
                            invisible="active"/>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="family"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripción">
                            <field name="description"/>
                        </page>
                        <page string="Prompt base de personalidad">
                            <field name="base_personality_prompt"
                                   widget="text"
                                   placeholder="Tono, jerga, dos-tres reglas globales del nicho..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vertical_template" model="ir.actions.act_window">
        <field name="name">Plantillas de Vertical</field>
        <field name="res_model">innatum.vertical.template</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
