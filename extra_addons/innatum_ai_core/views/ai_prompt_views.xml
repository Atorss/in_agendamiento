<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ai_prompt_list" model="ir.ui.view">
        <field name="name">innatum.ai.prompt.list</field>
        <field name="model">innatum.ai.prompt</field>
        <field name="arch" type="xml">
            <list string="Prompts del Agente">
                <field name="code"/>
                <field name="name"/>
                <field name="version"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_ai_prompt_form" model="ir.ui.view">
        <field name="name">innatum.ai.prompt.form</field>
        <field name="model">innatum.ai.prompt</field>
        <field name="arch" type="xml">
            <form string="Sección de Prompt">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="version"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contenido">
                            <field name="content" widget="text"
                                   placeholder="Cuerpo del prompt (puede usar variables {placeholder} interpretadas por el composer)..."/>
                        </page>
                        <page string="Notas">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_prompt" model="ir.actions.act_window">
        <field name="name">Prompts del Agente</field>
        <field name="res_model">innatum.ai.prompt</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
