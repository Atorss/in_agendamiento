<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Record rules para aislamiento multi-company.

            Modelo: 1 BD con N res.company (uno por tenant). Sin rules, el
            admin de un tenant podría ver/editar registros de otros tenants.

            Patrón Odoo para multi-company con super-admin:
              - 1 rule por GRUPO base.group_user (todos los usuarios internos):
                filtra por allowed_company_ids del switcher.
              - 1 rule por GRUPO base.group_system (Innatum staff):
                SIN filtro (ve todo, independiente del switcher).

            Cuando un usuario tiene VARIOS grupos, Odoo aplica OR entre las
            rules de esos grupos. Por eso el system admin (que tiene ambos)
            ve TODO: la rule de system permite [(1,1,1)] aunque la de user
            esté filtrada.

            El tenant admin (cliente final) solo tiene base.group_user (NO
            system), así que solo aplica la rule de user → filtrada por
            company.
        -->


        <!-- ===== innatum.business.profile ===== -->

        <record id="business_profile_company_rule" model="ir.rule">
            <field name="name">Business Profile: filtrar por compañía (usuarios)</field>
            <field name="model_id" ref="model_innatum_business_profile"/>
            <field name="domain_force">
                [('company_id', 'in', company_ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="business_profile_system_rule" model="ir.rule">
            <field name="name">Business Profile: acceso total (Innatum staff)</field>
            <field name="model_id" ref="model_innatum_business_profile"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>


        <!-- ===== innatum.ai.session ===== -->

        <record id="ai_session_company_rule" model="ir.rule">
            <field name="name">AI Session: filtrar por compañía (usuarios)</field>
            <field name="model_id" ref="model_innatum_ai_session"/>
            <field name="domain_force">
                [('company_id', 'in', company_ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="ai_session_system_rule" model="ir.rule">
            <field name="name">AI Session: acceso total (Innatum staff)</field>
            <field name="model_id" ref="model_innatum_ai_session"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>


        <!-- ===== innatum.ai.session.message ===== -->

        <record id="ai_session_message_company_rule" model="ir.rule">
            <field name="name">AI Session Message: filtrar por compañía via sesión</field>
            <field name="model_id" ref="model_innatum_ai_session_message"/>
            <field name="domain_force">
                [('session_id.company_id', 'in', company_ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="ai_session_message_system_rule" model="ir.rule">
            <field name="name">AI Session Message: acceso total (Innatum staff)</field>
            <field name="model_id" ref="model_innatum_ai_session_message"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>


        <!-- ===== innatum.business.knowledge ===== -->

        <record id="business_knowledge_company_rule" model="ir.rule">
            <field name="name">Business Knowledge: filtrar por compañía (usuarios)</field>
            <field name="model_id" ref="model_innatum_business_knowledge"/>
            <field name="domain_force">
                [('company_id', 'in', company_ids)]
            </field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="business_knowledge_system_rule" model="ir.rule">
            <field name="name">Business Knowledge: acceso total (Innatum staff)</field>
            <field name="model_id" ref="model_innatum_business_knowledge"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        </record>

    </data>
</odoo>
