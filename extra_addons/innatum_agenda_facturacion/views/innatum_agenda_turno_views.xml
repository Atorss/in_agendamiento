<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST: muestra estado de facturación como badge -->
    <record id="innatum_agenda_turno_list_inherit_facturacion" model="ir.ui.view">
        <field name="name">innatum.agenda.turno.list.facturacion</field>
        <field name="model">innatum.agenda.turno</field>
        <field name="inherit_id" ref="innatum_agenda_core.innatum_agenda_turno_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="after">
                <field name="sale_order_id" optional="hide" string="Pedido"/>
                <field name="sale_order_state" string="Facturación" optional="show"
                       widget="badge"
                       decoration-info="sale_order_state == 'draft'"
                       decoration-warning="sale_order_state == 'sent'"
                       decoration-success="sale_order_state == 'sale'"
                       decoration-muted="sale_order_state in ('cancel', False)"/>
            </xpath>
        </field>
    </record>

    <!-- KANBAN: badge "Facturado" en la tarjeta -->
    <record id="innatum_agenda_turno_kanban_inherit_facturacion" model="ir.ui.view">
        <field name="name">innatum.agenda.turno.kanban.facturacion</field>
        <field name="model">innatum.agenda.turno</field>
        <field name="inherit_id" ref="innatum_agenda_core.innatum_agenda_turno_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='servicio_id']" position="after">
                <field name="sale_order_id"/>
                <field name="sale_order_state"/>
            </xpath>
            <xpath expr="//div[hasclass('mb-2')]" position="after">
                <div t-if="record.sale_order_id.raw_value" class="mb-1">
                    <span t-attf-class="badge rounded-pill #{record.sale_order_state.raw_value == 'sale' ? 'text-bg-success' : record.sale_order_state.raw_value == 'cancel' ? 'text-bg-danger' : 'text-bg-info'}">
                        <i class="fa fa-file-text-o me-1"/>
                        <t t-if="record.sale_order_state.raw_value == 'sale'">Facturado</t>
                        <t t-elif="record.sale_order_state.raw_value == 'cancel'">Pedido cancelado</t>
                        <t t-elif="record.sale_order_state.raw_value == 'sent'">Enviado</t>
                        <t t-else="">Cotización</t>
                    </span>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Form: botones Facturar / Ver Pedido + campo sale_order_id -->
    <record id="innatum_agenda_turno_form_inherit_facturacion" model="ir.ui.view">
        <field name="name">innatum.agenda.turno.form.facturacion</field>
        <field name="model">innatum.agenda.turno</field>
        <field name="inherit_id" ref="innatum_agenda_core.innatum_agenda_turno_view_form"/>
        <field name="arch" type="xml">

            <!-- Botones en el header (antes del statusbar) -->
            <xpath expr="//header/field[@name='state']" position="before">
                <field name="can_facturar" invisible="1"/>
                <button name="action_facturar" type="object"
                        string="Facturar" class="btn-primary" icon="fa-file-text-o"
                        invisible="not can_facturar"/>
                <button name="action_view_sale_order" type="object"
                        string="Ver Pedido" class="btn-secondary" icon="fa-external-link"
                        invisible="not sale_order_id"/>
            </xpath>

            <!-- Mostrar el pedido de venta y su estado en el grupo "Servicio y Profesional" -->
            <xpath expr="//field[@name='config_id']" position="after">
                <field name="sale_order_id" invisible="not sale_order_id"
                       options="{'no_create': True, 'no_open': False}"/>
                <field name="sale_order_state" invisible="not sale_order_id"
                       widget="badge"
                       decoration-info="sale_order_state == 'draft'"
                       decoration-warning="sale_order_state == 'sent'"
                       decoration-success="sale_order_state == 'sale'"
                       decoration-muted="sale_order_state == 'cancel'"/>
            </xpath>
        </field>
    </record>

</odoo>
