<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form: agrega producto y precio en grupo "Facturación" + botón crear producto -->
    <record id="innatum_agenda_servicio_form_inherit_facturacion" model="ir.ui.view">
        <field name="name">innatum.agenda.servicio.form.facturacion</field>
        <field name="model">innatum.agenda.servicio</field>
        <field name="inherit_id" ref="innatum_agenda_core.innatum_agenda_servicio_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="action_crear_producto" type="object"
                            class="oe_stat_button" icon="fa-cube"
                            invisible="product_id">
                        <span>Crear<br/>Producto</span>
                    </button>
                </div>
            </xpath>
            <xpath expr="//field[@name='code']" position="after">
                <field name="precio" widget="monetary"/>
                <field name="product_id"
                       readonly="1"
                       options="{'no_create': True, 'no_open': False}"/>
            </xpath>
        </field>
    </record>

    <!-- List: agrega columna precio -->
    <record id="innatum_agenda_servicio_list_inherit_facturacion" model="ir.ui.view">
        <field name="name">innatum.agenda.servicio.list.facturacion</field>
        <field name="model">innatum.agenda.servicio</field>
        <field name="inherit_id" ref="innatum_agenda_core.innatum_agenda_servicio_view_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="precio" widget="monetary" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
