<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Smart buttons en el button_box de la vista simplificada de empresa
         (definida en innatum_agenda_admin):
         - Facturación Electrónica → form de Localización EC
         - Certificados SRI → lista de certificados (subir nuevos) -->
    <record id="res_company_form_inherit_facturacion" model="ir.ui.view">
        <field name="name">res.company.empresa.form.facturacion</field>
        <field name="model">res.company</field>
        <field name="inherit_id"
                ref="innatum_agenda_admin.innatum_agenda_admin_empresa_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(certificate.certificate_certificate_action_view_list)d"
                        type="action"
                        class="oe_stat_button" icon="fa-certificate">
                    <span>Certificados<br/>SRI</span>
                </button>
                <button name="action_open_ec_localization" type="object"
                        class="oe_stat_button" icon="fa-file-text-o">
                    <span>Facturación<br/>Electrónica</span>
                </button>
            </xpath>
        </field>
    </record>

    <!-- Form primario solo con campos de localización ecuatoriana.
         Se invoca explícitamente desde el smart button. Restringido al
         grupo Admin de Agenda para que no aparezca como default a
         otros usuarios del sistema. -->
    <record id="res_company_localizacion_ec_form" model="ir.ui.view">
        <field name="name">res.company.localizacion.ec.form</field>
        <field name="model">res.company</field>
        <field name="mode">primary</field>
        <field name="priority">99</field>
        <field name="groups_id" eval="[(6, 0, [
            ref('innatum_agenda_core.innatum_agenda_group_admin'),
        ])]"/>
        <field name="arch" type="xml">
            <form string="Localización Ecuatoriana"
                  duplicate="false" create="false" edit="true" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h3 class="text-muted">Localización Ecuatoriana</h3>
                    </div>
                    <group>
                        <field name="l10n_ec_legal_name"
                               string="Razón Social"
                               placeholder="Nombre exacto en el SRI"/>
                        <field name="l10n_ec_edi_certificate_id"
                               string="Firma Electrónica"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                    <div class="alert alert-info" role="status">
                        <i class="fa fa-info-circle"/>
                        Para configurar régimen, contribuyente especial, modo
                        producción u otros parámetros avanzados, contactá al
                        administrador del sistema.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
