<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Inserta los menús raíz "Sales" (Ventas) y "Invoicing" (Contabilidad)
             en el grupo "Gestion Financiera" de la sidebar MUK. -->
        <record id="muk_web_appsbar.menu_group_medic_financiero" model="ir.ui.menu.group">
            <field name="menu_ids" eval="[
                (4, ref('sale.sale_menu_root')),
                (4, ref('account.menu_finance')),
            ]"/>
        </record>

        <!-- Restringir el menú raíz "Facturación" al grupo Contador
             (account.group_account_user). Por defecto Odoo lo muestra a
             cualquier usuario con Billing (account.group_account_invoice),
             grupo que en este SaaS también tienen los doctores con
             "puede_facturar" — pero ellos acceden a sus facturas vía el
             menú "Mis Facturas" dentro de Agendamiento, no como app.
             group_account_user implica Billing, así que contadores siguen
             viendo todo normalmente. -->
        <record id="account.menu_finance" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('account.group_account_user')])]"/>
        </record>

    </data>
</odoo>
