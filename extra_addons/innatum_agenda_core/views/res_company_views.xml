<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_company_form_innatum_agenda" model="ir.ui.view">
        <field name="name">res.company.form.innatum.agenda</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Innatum Agenda" name="innatum_agenda">
                    <field name="vertical"/>
                    <field name="agenda_modo"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
