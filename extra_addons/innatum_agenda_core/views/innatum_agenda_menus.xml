<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Menú raíz -->
    <menuitem id="innatum_agenda_menu_root" name="Agendamiento"
              web_icon="innatum_agenda_core,static/description/agenda.png"
              sequence="25"/>

    <!-- Submenús -->
    <menuitem id="innatum_agenda_menu_turnos" name="Turnos"
              parent="innatum_agenda_menu_root"
              action="innatum_agenda_turno_action"
              sequence="10"/>

    <menuitem id="innatum_agenda_menu_planificacion" name="Planificación"
              parent="innatum_agenda_menu_root"
              action="innatum_agenda_config_action"
              sequence="20"/>

    <!-- Configuración -->
    <menuitem id="innatum_agenda_menu_config" name="Configuración"
              parent="innatum_agenda_menu_root"
              sequence="90"
              groups="innatum_agenda_group_admin"/>

    <!-- Servicios ahora es catálogo centralizado de Innatum (M2M
         company_ids). El admin del tenant solo puede LEER, no crear/
         editar. Para evitar confusión (admin clickea Nuevo y le sale
         AccessError), ocultamos este menú para todos excepto el admin
         del sistema. Innatum admin ya tiene "Catálogo de servicios" en
         "Innatum SaaS" con vista CRUD. -->
    <menuitem id="innatum_agenda_menu_servicios" name="Servicios"
              parent="innatum_agenda_menu_config"
              action="innatum_agenda_servicio_action"
              sequence="10"
              groups="base.group_system"/>

</odoo>
