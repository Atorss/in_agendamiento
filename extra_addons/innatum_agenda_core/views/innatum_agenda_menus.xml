<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Menú raíz -->
    <menuitem id="innatum_agenda_menu_root" name="Agendamiento"
              web_icon="innatum_agenda_core,static/description/agenda.png"
              sequence="25"/>

    <!-- Submenús -->
    <menuitem id="innatum_agenda_menu_turnos" name="Turnos"
              parent="innatum_agenda_menu_root"
              action="innatum_agenda_turno_action"
              sequence="10"/>

    <!-- Planificación: solo para tenants en modo 'planificada' (grupo técnico
         auto-gestionado) + Innatum staff (base.group_system) que ve todo. -->
    <menuitem id="innatum_agenda_menu_planificacion" name="Planificación"
              parent="innatum_agenda_menu_root"
              action="innatum_agenda_config_action"
              sequence="20"
              groups="innatum_agenda_group_modo_planificada,base.group_system"/>

    <!-- Configuración -->
    <menuitem id="innatum_agenda_menu_config" name="Configuración"
              parent="innatum_agenda_menu_root"
              sequence="90"
              groups="innatum_agenda_group_admin"/>

    <!-- Servicios es POR TENANT: cada empresa administra sus propios
         servicios (company_id M2O). El admin del tenant (innatum_agenda_group_admin)
         los crea/edita/borra — coherente con el ACL (1,1,1,1) y el record rule
         de aislamiento por company. Innatum staff además tiene su propia vista
         "Catálogo de servicios" en el menú "Innatum SaaS". -->
    <menuitem id="innatum_agenda_menu_servicios" name="Servicios"
              parent="innatum_agenda_menu_config"
              action="innatum_agenda_servicio_action"
              sequence="10"
              groups="innatum_agenda_group_admin"/>

</odoo>
