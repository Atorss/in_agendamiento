<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="innatum_agenda_bloqueo_view_list" model="ir.ui.view">
        <field name="name">innatum.agenda.bloqueo.list</field>
        <field name="model">innatum.agenda.bloqueo</field>
        <field name="arch" type="xml">
            <list string="Bloqueos">
                <field name="professional_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="motivo"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="innatum_agenda_bloqueo_view_form" model="ir.ui.view">
        <field name="name">innatum.agenda.bloqueo.form</field>
        <field name="model">innatum.agenda.bloqueo</field>
        <field name="arch" type="xml">
            <form string="Bloqueo">
                <sheet>
                    <group>
                        <group>
                            <!-- Personal: se precarga el propio empleado y no
                                 se puede cambiar (cada uno crea los suyos). -->
                            <field name="professional_id" readonly="1"
                                   options="{'no_create': True}"/>
                            <field name="motivo" placeholder="Ej: Reunión, almuerzo, mantenimiento"/>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="innatum_agenda_bloqueo_view_calendar" model="ir.ui.view">
        <field name="name">innatum.agenda.bloqueo.calendar</field>
        <field name="model">innatum.agenda.bloqueo</field>
        <field name="arch" type="xml">
            <calendar string="Bloqueos" date_start="date_start" date_stop="date_end"
                      color="color" mode="week" event_open_popup="1"
                      quick_create="0">
                <field name="professional_id" filters="1"/>
                <field name="motivo"/>
                <field name="color" invisible="1"/>
            </calendar>
        </field>
    </record>

    <record id="innatum_agenda_bloqueo_action" model="ir.actions.act_window">
        <field name="name">Bloqueos</field>
        <field name="res_model">innatum.agenda.bloqueo</field>
        <field name="view_mode">calendar,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sin bloqueos
            </p>
            <p>
                Registrá los espacios en los que un profesional NO puede
                recibir turnos (reuniones, ausencias puntuales, etc.). En el
                modo de agenda Directa, esos espacios se restan de la
                disponibilidad.
            </p>
        </field>
    </record>

    <!-- Bloqueos: solo para tenants en modo 'directa' (grupo técnico
         auto-gestionado) + Innatum staff (base.group_system) que ve todo.
         En modo planificada no aplica (la disponibilidad la dan los slots). -->
    <menuitem id="innatum_agenda_menu_bloqueos" name="Bloqueos"
              parent="innatum_agenda_menu_root"
              action="innatum_agenda_bloqueo_action"
              sequence="25"
              groups="innatum_agenda_group_modo_directa,base.group_system"/>

</odoo>
