<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Override de la rule estándar de res.partner para SaaS
         multi-tenant.

         La rule original de Odoo (base.res_partner_rule) dice que
         partners con partner_share=False (typical Internal Users
         como admins y empleados) son visibles para TODOS los users
         sin importar su company. Eso filtra el email/login del admin
         del tenant B hacia los users del tenant A — fuga de
         información inaceptable en un SaaS.

         Nuestra versión solo permite ver partners de las companies
         del user actual, o partners "del sistema" (company_id=False
         queda para Administrator, OdooBot, etc., que son globales).
         ============================================================ -->

    <record id="base.res_partner_rule" model="ir.rule">
        <field name="name">res.partner company (multi-tenant override)</field>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else ['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]</field>
    </record>

    <!-- Override base.res_users_rule: admin sistema ve todos los usuarios
         cross-company sin tocar el switcher; tenants ven solo internal
         users + users de su company. -->
    <record id="base.res_users_rule" model="ir.rule">
        <field name="name">res.users company (multi-tenant override)</field>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else ['|', ('share', '=', False), ('company_ids', 'in', company_ids)]</field>
    </record>

    <!-- Override hr.hr_employee_comp_rule: admin sistema ve todos los
         empleados cross-company. Tenants mantienen el filtro original. -->
    <record id="hr.hr_employee_comp_rule" model="ir.rule">
        <field name="name">Employee multi company rule (multi-tenant override)</field>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else ['|', '|', '|', ('company_id', 'in', company_ids + [False]), ('parent_id.user_id', '=', user.id), ('id', '=', user.employee_id.parent_id.id), ('user_id', '=', user.id)]</field>
    </record>

    <!-- ============================================================
         Multi-company global rules (aislamiento entre tenants)

         Se aplican con AND a todas las queries. Garantizan que ningún
         usuario (ni siquiera con sudo a través de un grupo) vea datos
         de otro tenant. Para data accesible desde el sitio público,
         los controllers deben filtrar adicionalmente por
         request.website.company_id porque corren con .sudo().
         ============================================================ -->

    <!-- Servicio es POR TENANT: cada empresa administra sus propios
         servicios. El admin del tenant ve y gestiona solo los de su(s)
         company(s) (company_id en sus allowed companies). El bypass de
         base.group_system permite a Innatum (admin del sistema) ver TODOS
         los servicios de todos los tenants. -->
    <record id="rule_servicio_multi_company" model="ir.rule">
        <field name="name">Servicio: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_servicio"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_turno_multi_company" model="ir.rule">
        <field name="name">Turno: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_turno"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_bloqueo_multi_company" model="ir.rule">
        <field name="name">Bloqueo: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_bloqueo"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_calendario_multi_company" model="ir.rule">
        <field name="name">Calendario unificado: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_calendario"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('company_id', 'in', company_ids)]</field>
    </record>

    <record id="rule_config_multi_company" model="ir.rule">
        <field name="name">Planificación: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_config"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('company_id', 'in', company_ids)]</field>
    </record>

    <!-- Líneas de planificación: hijas de config; el modelo no tiene
         company_id propio, se aísla por la company del config padre. -->
    <record id="rule_config_line_multi_company" model="ir.rule">
        <field name="name">Línea de planificación: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_config_line"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('config_id.company_id', 'in', company_ids)]</field>
    </record>

    <!-- ============================================================
         Record Rules para innatum.agenda.config (Planificación)
         ============================================================ -->

    <!-- Operador/Admin: acceso total a planificaciones (dentro del tenant) -->
    <record id="rule_config_operator_all" model="ir.rule">
        <field name="name">Planificación: operador ve todo</field>
        <field name="model_id" ref="model_innatum_agenda_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_operator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Usuario: solo sus planificaciones -->
    <record id="rule_config_user_own" model="ir.rule">
        <field name="name">Planificación: usuario ve solo las suyas</field>
        <field name="model_id" ref="model_innatum_agenda_config"/>
        <field name="domain_force">[
            '|',
            ('professional_id.user_id', '=', user.id),
            ('professional_id', '=', False),
        ]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ============================================================
         Record Rules para innatum.agenda.turno
         ============================================================ -->

    <!-- Operador/Admin: acceso total a turnos (dentro del tenant) -->
    <record id="rule_turno_operator_all" model="ir.rule">
        <field name="name">Turno: operador ve todo</field>
        <field name="model_id" ref="model_innatum_agenda_turno"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_operator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Usuario: sus turnos (donde atiende) + las derivaciones que originó -->
    <record id="rule_turno_user_own" model="ir.rule">
        <field name="name">Turno: usuario ve solo los suyos</field>
        <field name="model_id" ref="model_innatum_agenda_turno"/>
        <field name="domain_force">['|',
            ('professional_id.user_id', '=', user.id),
            ('derivado_por_id.user_id', '=', user.id),
        ]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ============================================================
         Record Rule para innatum.agenda.bloqueo
         ============================================================ -->

    <!-- Bloqueos son PERSONALES: cada profesional crea/ve/edita solo los
         SUYOS. A diferencia de los turnos, NO hay regla "operator/admin ve
         todo": aquí ni el admin del tenant edita bloqueos ajenos (no tiene
         lógica que gestione las reuniones/ausencias de otro).

         La regla se aplica a innatum_agenda_group_user; como Operador y
         Admin implican Usuario, también quedan restringidos a lo suyo.
         Innatum (base.group_system) no es miembro de estos grupos, así que
         solo le aplica la regla global de company (ve todo). -->
    <record id="rule_bloqueo_user_own" model="ir.rule">
        <field name="name">Bloqueo: cada profesional solo los suyos</field>
        <field name="model_id" ref="model_innatum_agenda_bloqueo"/>
        <field name="domain_force">[
            ('professional_id.user_id', '=', user.id),
        ]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ============================================================
         Record Rules para innatum.agenda.turno.propuesta
         (horarios propuestos de una derivación)
         ============================================================ -->

    <!-- Aislamiento por tenant (global, bypass sistema) -->
    <record id="rule_turno_propuesta_multi_company" model="ir.rule">
        <field name="name">Propuesta: aislamiento por tenant</field>
        <field name="model_id" ref="model_innatum_agenda_turno_propuesta"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[(1, '=', 1)] if user.has_group('base.group_system') else [('derivacion_id.company_id', 'in', company_ids)]</field>
    </record>

    <!-- Operador/Admin: ven todas las del tenant -->
    <record id="rule_turno_propuesta_operator_all" model="ir.rule">
        <field name="name">Propuesta: operador ve todas</field>
        <field name="model_id" ref="model_innatum_agenda_turno_propuesta"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_operator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Usuario: solo propuestas de sus derivaciones (atiende o derivó) -->
    <record id="rule_turno_propuesta_user_own" model="ir.rule">
        <field name="name">Propuesta: usuario ve donde participa</field>
        <field name="model_id" ref="model_innatum_agenda_turno_propuesta"/>
        <field name="domain_force">['|',
            ('derivacion_id.professional_id.user_id', '=', user.id),
            ('derivacion_id.derivado_por_id.user_id', '=', user.id),
        ]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Filtro del calendario: cada usuario solo ve/gestiona los suyos -->
    <record id="rule_calendario_filtro_own" model="ir.rule">
        <field name="name">Filtro calendario: solo los propios</field>
        <field name="model_id" ref="model_innatum_agenda_calendario_filtro"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('innatum_agenda_group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
