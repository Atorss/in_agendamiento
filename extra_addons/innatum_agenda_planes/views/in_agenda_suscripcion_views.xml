<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_in_agenda_suscripcion_list" model="ir.ui.view">
        <field name="name">in_agenda.suscripcion.list</field>
        <field name="model">in_agenda.suscripcion</field>
        <field name="arch" type="xml">
            <list string="Suscripciones"
                  decoration-success="state == 'active'"
                  decoration-info="state == 'trial'"
                  decoration-warning="state == 'suspended'"
                  decoration-muted="state in ('expired', 'cancelled')">
                <field name="name"/>
                <field name="company_id"/>
                <field name="plan_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="ai_margin_pct"/>
                <field name="tokens_restantes_total_usd" sum="Total restante"/>
                <field name="state" widget="badge"/>
                <field name="active" column_invisible="True"/>
            </list>
        </field>
    </record>

    <record id="view_in_agenda_suscripcion_form" model="ir.ui.view">
        <field name="name">in_agenda.suscripcion.form</field>
        <field name="model">in_agenda.suscripcion</field>
        <field name="arch" type="xml">
            <form string="Suscripción">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="trial,active,suspended,expired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                                name="action_view_recargas"
                                icon="fa-money">
                            <field name="recarga_count" widget="statinfo"
                                   string="Recargas IA"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Tenant y plan">
                            <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="plan_id"/>
                            <field name="ciclo_facturacion" widget="radio" options="{'horizontal': True}"/>
                            <field name="precio_aplicado_usd" readonly="1"/>
                            <field name="external_ref" readonly="1"/>
                        </group>
                        <group string="Vigencia">
                            <field name="fecha_inicio"/>
                            <field name="fecha_fin"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Funcionalidades incluidas (gratis)">
                        <field name="facturacion_sri_habilitada"/>
                    </group>
                    <group string="Add-ons de cobro (vigencia por fechas)">
                        <field name="addon_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="addon_id"/>
                                <field name="es_gratis" readonly="1" optional="hide"/>
                                <field name="fecha_inicio"/>
                                <field name="fecha_fin"/>
                                <field name="precio_mensual_usd"/>
                                <field name="precio_anual_usd"/>
                                <field name="activo_hoy" widget="boolean_toggle" readonly="1"/>
                            </list>
                        </field>
                        <group>
                            <field name="precio_aplicado_usd" readonly="1" string="Plan base (período)"/>
                            <field name="precio_addons_usd" readonly="1"/>
                            <field name="precio_total_usd" readonly="1" class="fw-bold"/>
                        </group>
                    </group>
                    <group string="Servicios habilitados para el tenant">
                        <field name="servicio_ids" nolabel="1" colspan="2"
                               widget="many2many_tags"
                               options="{'no_create': True, 'no_create_edit': True}"/>
                    </group>
                    <group string="IA">
                        <group>
                            <field name="ai_margin_pct"/>
                        </group>
                        <group>
                            <field name="tokens_disponibles_total_usd"/>
                            <field name="tokens_consumidos_total_usd"/>
                            <field name="tokens_restantes_total_usd"
                                   decoration-danger="tokens_restantes_total_usd &lt; 0.5"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Recargas IA">
                            <field name="recarga_ids">
                                <list editable="bottom">
                                    <field name="fecha"/>
                                    <field name="monto_cobrado_usd"/>
                                    <field name="margen_pct_aplicado" readonly="1"/>
                                    <field name="tokens_disponibles_usd"/>
                                    <field name="tokens_consumidos_usd"/>
                                    <field name="tokens_restantes_usd"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notas internas">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_in_agenda_suscripcion_search" model="ir.ui.view">
        <field name="name">in_agenda.suscripcion.search</field>
        <field name="model">in_agenda.suscripcion</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="company_id"/>
                <field name="plan_id"/>
                <field name="external_ref"/>
                <separator/>
                <filter string="Activas" name="filter_active"
                        domain="[('state', '=', 'active')]"/>
                <filter string="Trial" name="filter_trial"
                        domain="[('state', '=', 'trial')]"/>
                <filter string="Vencidas" name="filter_expired"
                        domain="[('state', '=', 'expired')]"/>
                <group string="Agrupar por">
                    <filter string="Estado" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Plan" name="group_plan"
                            context="{'group_by': 'plan_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_in_agenda_suscripcion" model="ir.actions.act_window">
        <field name="name">Suscripciones</field>
        <field name="res_model">in_agenda.suscripcion</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
