<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_in_agenda_tenant_wizard_form" model="ir.ui.view">
        <field name="name">in_agenda.tenant.wizard.form</field>
        <field name="model">in_agenda.tenant.wizard</field>
        <field name="arch" type="xml">
            <form string="Provisionar tenant">
                <sheet>
                    <div class="oe_title">
                        <h1>Crear nuevo tenant SaaS</h1>
                        <p class="text-muted">
                            Crea company + website (con subdominio) + admin user
                            del tenant + suscripción inicial — todo en una sola
                            transacción.
                        </p>
                    </div>
                    <group>
                        <group string="Tenant">
                            <field name="name" placeholder="Peluquería Estilo"/>
                            <field name="subdomain" placeholder="estilo"/>
                            <field name="domain_scheme"/>
                            <field name="base_domain"/>
                            <field name="vertical"/>
                            <field name="country_id"/>
                            <field name="currency_id"/>
                            <field name="timezone"/>
                        </group>
                        <group string="Admin del tenant">
                            <field name="admin_email" placeholder="admin@estilo.com"/>
                            <field name="admin_name" placeholder="Nombre completo"/>
                            <field name="admin_password" password="True"/>
                            <field name="crear_empleado_admin"/>
                            <field name="admin_identification_id"
                                   placeholder="1234567890"
                                   invisible="not crear_empleado_admin"/>
                            <field name="admin_work_phone"
                                   placeholder="09XXXXXXXX"
                                   invisible="not crear_empleado_admin"/>
                            <field name="admin_job_title"
                                   placeholder="Dueña, Estilista, Veterinario, etc."
                                   invisible="not crear_empleado_admin"/>
                        </group>
                    </group>
                    <group string="Suscripción">
                        <group>
                            <field name="plan_id"/>
                            <field name="ciclo_facturacion" widget="radio"
                                   options="{'horizontal': True}"/>
                            <field name="state_inicial"/>
                        </group>
                        <group>
                            <field name="fecha_inicio"/>
                            <label for="duracion"/>
                            <div class="o_row">
                                <field name="duracion"/>
                                <span invisible="ciclo_facturacion != 'anual'">año(s)</span>
                                <span invisible="ciclo_facturacion != 'mensual'">mes(es)</span>
                                <span class="text-muted ms-2">= <field name="duracion_meses_total" class="oe_inline"/> meses</span>
                            </div>
                        </group>
                    </group>
                    <group string="Funcionalidades incluidas (gratis)">
                        <field name="facturacion_sri_habilitada"/>
                    </group>
                    <group string="Add-ons de cobro a activar (precio del catálogo, desde el inicio)">
                        <field name="addon_ids" nolabel="1" colspan="2"
                               widget="many2many_tags"
                               options="{'no_create': True, 'color_field': 'sequence'}"/>
                    </group>
                    <group string="Servicios habilitados para este tenant">
                        <field name="servicio_ids" nolabel="1"
                               widget="many2many_tags"
                               options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Crear tenant" type="object"
                            name="action_provision_tenant" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_in_agenda_tenant_wizard" model="ir.actions.act_window">
        <field name="name">Crear tenant</field>
        <field name="res_model">in_agenda.tenant.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
