<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Red de rescate del canal saliente WhatsApp: despacha lo pendiente
         cada 5 minutos. El camino rápido es el trigger post-commit que
         dispara queue_template() al encolar. -->
    <data noupdate="1">
    <record id="ir_cron_wa_outbound_dispatch" model="ir.cron">
        <field name="name">Innatum WA: despachar cola saliente</field>
        <field name="model_id" ref="model_innatum_wa_outbound"/>
        <field name="state">code</field>
        <field name="code">model._dispatch_pending()</field>
        <field name="interval_number">5</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
    </data>
</odoo>
