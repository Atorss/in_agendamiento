<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="innatum_wa_outbound_view_list" model="ir.ui.view">
        <field name="name">innatum.wa.outbound.list</field>
        <field name="model">innatum.wa.outbound</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'failed'"
                  decoration-success="state == 'sent'"
                  decoration-muted="state == 'cancelled'">
                <field name="create_date"/>
                <field name="company_id"/>
                <field name="category"/>
                <field name="to_number"/>
                <field name="state"/>
                <field name="attempts"/>
                <field name="next_attempt_at" optional="hide"/>
                <field name="error_message" optional="show"/>
            </list>
        </field>
    </record>

    <record id="innatum_wa_outbound_view_form" model="ir.ui.view">
        <field name="name">innatum.wa.outbound.form</field>
        <field name="model">innatum.wa.outbound</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_requeue" type="object"
                            string="Re-encolar" class="btn-primary"
                            invisible="state != 'failed'"/>
                    <button name="action_cancel_message" type="object"
                            string="Cancelar envío"
                            invisible="state not in ('pending', 'failed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,sending,sent"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="category"/>
                            <field name="to_number"/>
                            <field name="res_model"/>
                            <field name="res_id"/>
                        </group>
                        <group>
                            <field name="attempts"/>
                            <field name="next_attempt_at"/>
                            <field name="wamid"/>
                        </group>
                    </group>
                    <group string="Último error" invisible="not error_message">
                        <field name="error_message" nolabel="1"/>
                    </group>
                    <group string="Payload Meta">
                        <field name="meta_payload" nolabel="1" readonly="1"
                               widget="jsonb"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="innatum_wa_outbound_action" model="ir.actions.act_window">
        <field name="name">Cola WhatsApp saliente</field>
        <field name="res_model">innatum.wa.outbound</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_no_sent': 1}</field>
    </record>

    <record id="innatum_wa_outbound_view_search" model="ir.ui.view">
        <field name="name">innatum.wa.outbound.search</field>
        <field name="model">innatum.wa.outbound</field>
        <field name="arch" type="xml">
            <search>
                <field name="to_number"/>
                <field name="company_id"/>
                <filter name="filter_no_sent" string="Pendientes y fallidos"
                        domain="[('state', 'in', ('pending', 'sending', 'failed'))]"/>
                <filter name="filter_failed" string="Fallidos"
                        domain="[('state', '=', 'failed')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_state" string="Estado"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_category" string="Categoría"
                            context="{'group_by': 'category'}"/>
                </group>
            </search>
        </field>
    </record>

    <menuitem id="menu_innatum_wa_outbound"
              name="Cola WhatsApp saliente"
              parent="innatum_agenda_ai.menu_ai_config"
              action="innatum_wa_outbound_action"
              groups="base.group_system"
              sequence="90"/>

</odoo>
