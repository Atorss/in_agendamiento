<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="innatum_wa_flow_keypair_view_list" model="ir.ui.view">
        <field name="name">innatum.wa.flow.keypair.list</field>
        <field name="model">innatum.wa.flow.keypair</field>
        <field name="arch" type="xml">
            <list>
                <field name="company_id"/>
                <field name="generated_at"/>
            </list>
        </field>
    </record>

    <record id="innatum_wa_flow_keypair_view_form" model="ir.ui.view">
        <field name="name">innatum.wa.flow.keypair.form</field>
        <field name="model">innatum.wa.flow.keypair</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate" type="object"
                            string="Generar claves" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="generated_at"/>
                    </group>
                    <group string="Clave pública">
                        <field name="public_key_pem" nolabel="1" readonly="1"/>
                    </group>
                    <group string="Clave privada" groups="base.group_system">
                        <field name="private_key_pem" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="innatum_wa_flow_keypair_action" model="ir.actions.act_window">
        <field name="name">Claves Flows</field>
        <field name="res_model">innatum.wa.flow.keypair</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_innatum_wa_flow_keypair"
              name="Claves Flows"
              parent="innatum_agenda_ai.menu_ai_config"
              action="innatum_wa_flow_keypair_action"
              groups="base.group_system"
              sequence="91"/>

</odoo>
