<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ai_session_list" model="ir.ui.view">
        <field name="name">innatum.ai.session.list</field>
        <field name="model">innatum.ai.session</field>
        <field name="arch" type="xml">
            <list string="Sesiones WhatsApp" create="0">
                <field name="create_date"/>
                <field name="company_id" optional="show"/>
                <field name="wa_from"/>
                <field name="partner_id"/>
                <field name="turno_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'nueva'"
                       decoration-warning="state in ('pendiente_pago','con_humano')"
                       decoration-success="state in ('confirmada','realizada')"
                       decoration-muted="state in ('cancelada','expirada')"/>
            </list>
        </field>
    </record>

    <record id="view_ai_session_form" model="ir.ui.view">
        <field name="name">innatum.ai.session.form</field>
        <field name="model">innatum.ai.session</field>
        <field name="arch" type="xml">
            <form string="Sesión WhatsApp" create="false" edit="false">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="nueva,identificando_cliente,conversando,buscando_disponibilidad,eligiendo_slot,confirmando,pendiente_pago,confirmada,realizada"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="wa_from"/>
                            <field name="partner_id"/>
                            <field name="turno_id"/>
                        </group>
                        <group>
                            <field name="token" readonly="1"/>
                            <field name="create_date" readonly="1"/>
                            <field name="expires_at"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mensajes" name="page_messages">
                            <field name="message_ids" readonly="1">
                                <list string="Mensajes">
                                    <field name="create_date"/>
                                    <field name="role"/>
                                    <field name="content"/>
                                    <field name="tokens_in" sum="Total in"/>
                                    <field name="tokens_out" sum="Total out"/>
                                    <field name="cost_usd" sum="Total USD"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ai_session_search" model="ir.ui.view">
        <field name="name">innatum.ai.session.search</field>
        <field name="model">innatum.ai.session</field>
        <field name="arch" type="xml">
            <search string="Buscar sesión">
                <field name="wa_from"/>
                <field name="partner_id"/>
                <field name="company_id"/>
                <filter name="filter_handoff" string="En handoff"
                        domain="[('state', '=', 'con_humano')]"/>
                <filter name="filter_active" string="Activas"
                        domain="[('state', 'not in', ('cancelada','realizada','expirada'))]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_company" string="Compañía" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Bandeja estilo Chatwoot (client action OWL). Reemplaza el list/form
         como acción de los menús "Sesiones WhatsApp". El act_window de abajo se
         conserva por si se necesita la vista clásica. -->
    <record id="action_ai_whatsapp_inbox" model="ir.actions.client">
        <field name="name">Sesiones WhatsApp</field>
        <field name="tag">innatum_agenda_ai.whatsapp_inbox</field>
    </record>

    <record id="action_ai_session" model="ir.actions.act_window">
        <field name="name">Sesiones WhatsApp</field>
        <field name="res_model">innatum.ai.session</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ai_session_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
    </record>

</odoo>
